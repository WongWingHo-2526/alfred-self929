{
  "name": "Flask with Docker",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "postCreateCommand": "",
  "postStartCommand": "flask --debug run --host=0.0.0.0 --port=5000",
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "Flask App",
      "onAutoForward": "openPreview"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
